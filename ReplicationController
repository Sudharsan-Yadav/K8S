---
apiVersion: v1
kind: ReplicationController
metadata:
  name: myrc
spec:
  replicas: 3
  selector:
    app: zomato
  template:
    metadata:
      name: pod1
      labels:
        app: zomato
    spec:
      containers:
        - name: cont1
          image: shaikmustafa/paytm:movie
          ports:
            - containerPort: 80
