---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: mydb
spec:
  replicas: 3
  selector:
    matchLabels:
      tier: db
  template:
    metadata:
      name: mypod
      labels:
        tier: db
    spec:
      containers:
        - name: mycont
          image: shaikmustafa/paytm:movie
          ports:
            - containerPort: 80
