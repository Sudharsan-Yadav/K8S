---
apiVersion: v1
kind: Pod
metadata:
  name: pod1
  namespace: dev
spec:
  containers:
    - name: mycont
      image: nginx
      ports:
        - containerPort: 80
      resources:
        requests:
          memory: "5Mi"
          cpu: "50m"
        limits:
          memory: "10Mi"
          cpu: "100m"
