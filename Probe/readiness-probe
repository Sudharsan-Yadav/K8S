---
apiVersion: v1
kind: Pod
metadata:
  name: readiness-pod
spec:
  containers:
    - name: mycont
      image: nginx
      ports:
        - containerPort: 80
      args:
        - /bin/sh
        - -c
        - touch /tmp/ready; sleep 1000
      readinessProbe:
        exec:
          command:
            - cat
            - /tmp/ready
        initialDelaySeconds: 5
        periodSeconds: 5
        timeoutSeconds: 30
