---
apiVersion: apps/v1
kind: ReplicaSet
metadata:
  name: myrs
spec:
  replicas: 3
  selector:
    matchLabels:
      app: zomato
  template:
    metadata:
      name: mypod
      labels:
        app: zomato
    spec:
      containers:
        - name: mycont
          image: shaikmustafa/paytm:bus
          ports:
            - containerPort: 80
