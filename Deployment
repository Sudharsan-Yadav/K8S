---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: flm
spec:
  replicas: 3
  selector:
    matchLabels:
      app: swiggy
  template:
    metadata:
      name: mypod
      labels:
        app: swiggy
    spec:
      containers:
        - name: mycont
          image: shaikmustafa/paytm:bus
          ports:
            - containerPort: 80
