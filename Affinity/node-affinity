---
apiVersion: v1
kind: Pod
metadata:
  name: nodeaffinity-pod
  labels:
    app: order
spec:
  containers:
    - name: cont1
      image: nginx
      ports:
       - containerPort: 80
  affinity:
    nodeAffinity:
      requiredDuringSchedulingIgnoredDuringExecution:
        nodeSelectorTerms:
        - matchExpressions:
          - key: app
            operator: In
            values:
            - swiggy
